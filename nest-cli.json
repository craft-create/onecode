{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "server",
  "compilerOptions": {
    "deleteOutDir": false,
    "tsConfigPath": "tsconfig.node.json",
    "assets": [
      {
        "include": "capabilities/**/*.json",
        "outDir": "dist/server",
        "watchAssets": true
      },
      {
        "include": "resources/fonts/*.otf",
        "outDir": "dist/server",
        "watchAssets": true
      }
    ],
    "plugins": []
  }
}

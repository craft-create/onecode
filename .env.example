# Copy to .env.local and fill real values
# App DB
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@localhost:5432/app_db

# 服务端口
SERVER_HOST=localhost
SERVER_PORT=3000
CLIENT_DEV_PORT=8080

# 上传文件持久化目录
# 留空则默认使用仓库根目录/data/uploads
UPLOAD_BASE_DIR=

# PDF 中文字体路径（可选）
# 留空时按内置路径顺序自动检测（建议优先填入可用的 TTF/TTC）
ONECODE_PDF_FONT_PATH=

# 日志目录
LOG_DIR=logs

# API 安全策略
# 频率限制（单位：毫秒窗口内允许请求数）
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=120
# 是否信任代理头进行 IP 识别（生产代理场景建议设置 true）
API_RATE_LIMIT_TRUST_PROXY_HEADERS=false
# XSS 检测字段（英文逗号分隔，匹配到这些字段将做危险内容检测）
API_XSS_PROTECT_FIELDS=url,callback,returnUrl,return_url,redirect,redirectUrl,next,html

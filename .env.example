# Copy to .env.local and fill real values
# App DB (优先级更高)
SUDA_DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@localhost:5432/app_db

# 可选：若你希望使用 DATABASE_URL，可改用这个变量（和 SUDA_DATABASE_URL 二选一即可）
# DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@localhost:5432/app_db

# 服务端口
SERVER_HOST=localhost
SERVER_PORT=3000
CLIENT_DEV_PORT=8080

# 上传文件持久化目录
# 留空则默认使用仓库根目录/data/uploads
UPLOAD_BASE_DIR=

# PDF 中文字体路径（可选）
# 留空时按内置路径顺序自动检测（建议优先填入可用的 TTF/TTC）
ONECODE_PDF_FONT_PATH=

# 日志目录
LOG_DIR=logs

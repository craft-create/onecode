{
  "name": "fullstack-nestjs-template",
  "version": "2.2.5",
  "private": true,
  "flags": {
    "supportBusinessUser": true,
    "supportScrollReveal": true,
    "supportTiptapAndStreamdown": true,
    "customToaster": true
  },
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:server": "NODE_ENV=development nest start --watch",
    "dev:client": "NODE_ENV=development vite --config vite.config.ts",
    "gen:db-schema": "echo \"Skipped: @lark-apaas/db-schema-sync removed from this project\"",
    "gen:openapi": "echo 'UNSUPPORTED, SKIP'",
    "build": "./scripts/build.sh",
    "build:prod": "npm run build:server && npm run build:client",
    "build:server": "NODE_ENV=production nest build",
    "build:client": "NODE_ENV=production vite build --config vite.config.ts",
    "start": "NODE_ENV=production node main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config test/e2e/jest.config.js",
    "eslint": "eslint . --quiet",
    "stylelint": "stylelint client/src/**/*.css --quiet",
    "type:check": "concurrently -n \"server,client\" -c \"blue,green\" \"npm run type:check:server\" \"npm run type:check:client\"",
    "type:check:client": "tsc --noEmit --project tsconfig.app.json",
    "type:check:server": "tsc --noEmit --project tsconfig.node.json",
    "lint": "node ./scripts/lint.js",
    "format": "prettier --write \"{server,client,test}/**/*.{js,ts,tsx,json,md}\"",
    "precommit": "node scripts/hooks/run-precommit.js",
    "prepare": "chmod +x .githooks/pre-commit 2>/dev/null; git config core.hooksPath .githooks 2>/dev/null || true",
    "dev:local": "node ./scripts/dev-local.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "@shikijs/core": "^4.3.1",
    "@shikijs/engine-javascript": "^4.3.1",
    "@shikijs/types": "^4.3.1",
    "@tanstack/react-form": "^1.27.6",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "0.44.6",
    "hbs": "^4.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.1.14"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.20",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/langs": "^3.23.0",
    "@shikijs/themes": "^3.23.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.14.0",
    "@tiptap/extension-code-block": "^3.15.3",
    "@tiptap/extension-color": "^3.14.0",
    "@tiptap/extension-highlight": "^3.14.0",
    "@tiptap/extension-image": "^3.14.0",
    "@tiptap/extension-link": "^3.14.0",
    "@tiptap/extension-placeholder": "^3.14.0",
    "@tiptap/extension-task-item": "^3.15.3",
    "@tiptap/extension-task-list": "^3.15.3",
    "@tiptap/extension-text-align": "^3.14.0",
    "@tiptap/extension-text-style": "^3.14.0",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "@types/bcrypt": "^6.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.3",
    "@types/hbs": "^4.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.18.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "~2.0.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "es-toolkit": "^1.43.0",
    "eslint": "^9.35.0",
    "framer-motion": "https://registry.npmjs.org/framer-motion/-/framer-motion-11.13.5.tgz",
    "input-otp": "^1.4.2",
    "jest": "^30.4.2",
    "lucide-react": "^0.554.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.0",
    "prettier": "^3.6.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-countup": "^6.5.3",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^3.0.6",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "rxjs": "^7.8.2",
    "shiki": "^3.23.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "stylelint": "^16.11.0",
    "tailwind-merge": "~3.4.0",
    "tailwindcss": "^4.1.13",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "uuid": "11.0.5",
    "vaul": "^1.1.2",
    "vite": "^7.3.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/server/**/*.spec.ts",
      "<rootDir>/test/unit/**/*.spec.ts"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true
  },
  "overrides": {
    "test-exclude": "^8.0.0",
    "glob": "^13.0.6"
  }
}
